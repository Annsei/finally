# FinAlly environment configuration (PLAN.md §5)
# Copy this file to .env and fill in your values:  cp .env.example .env

# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data.
# If not set (or empty), the built-in market simulator is used
# (recommended for most users).
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (E2E tests, CI,
# development without an API key).
LLM_MOCK=false
