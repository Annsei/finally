# FinAlly runtime configuration
# Copy to .env, keep .env private, and see planning/OPERATIONS.md for modes.

# ---------------------------------------------------------------------------
# Runtime boundary
# ---------------------------------------------------------------------------

# local-demo: loopback-only, name-only demo login is allowed.
# classroom-server: shared single-replica server; requires the two secrets below
# and FINALLY_SINGLE_REPLICA=true.
FINALLY_RUNTIME_MODE=local-demo

# Backend bind expectation used by RuntimeSettings/backend/run.py. local-demo
# accepts loopback hosts only. Docker still listens on 0.0.0.0 inside the
# container; FINALLY_BIND_HOST below controls the host-published interface.
FINALLY_HOST=127.0.0.1
FINALLY_SINGLE_REPLICA=true

# Required in classroom-server; use independent random values of 32+ bytes.
# Never reuse the OpenRouter key here.
FINALLY_SERVER_AUTH_SECRET=
# Blank in local-demo uses the loopback-only value "local-demo-admin".
FINALLY_ADMIN_TOKEN=

# Bearer request safety and quote freshness gates.
FINALLY_MAX_BEARER_BODY_BYTES=65536
FINALLY_QUOTE_MAX_AGE_SECONDS=45

# ---------------------------------------------------------------------------
# Product integrations and market behavior
# ---------------------------------------------------------------------------

# Required only for live AI calls. Leave empty when LLM_MOCK=true.
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) key for real US market data. Empty uses the
# built-in simulator. The CN profile always uses its configured simulator.
MASSIVE_API_KEY=

# Deterministic LLM behavior for tests/offline demonstrations.
LLM_MOCK=false

# Direct backend launches use this profile. docker-compose.yml pins its US and
# CN services independently, so one database volume never changes market.
FINALLY_MARKET=us

# Empty commission uses the profile default (US 0 bps, CN 2.5 bps).
FINALLY_COMMISSION_BPS=

# Accelerated simulator session clock. Both values must be positive; invalid or
# non-positive values select the documented 24/7 behavior.
FINALLY_SESSION_OPEN_SECONDS=1800
FINALLY_SESSION_BREAK_SECONDS=120

# Direct local backend default is db/finally.db. Docker Compose overrides this
# to the persistent /app/db/finally.db volume path.
DB_PATH=db/finally.db

# ---------------------------------------------------------------------------
# Host orchestration (scripts and Docker Compose; not backend application vars)
# ---------------------------------------------------------------------------

# Host interface published by Docker. Keep loopback unless intentionally
# operating a secured classroom-server behind TLS/reverse proxy controls.
FINALLY_BIND_HOST=127.0.0.1
FINALLY_US_PORT=8000
FINALLY_CN_PORT=8001

# start_mac.sh/start_windows.ps1 overrides. Compose uses project-scoped volumes
# instead, which prevents different checkouts from sharing a database.
FINALLY_IMAGE_NAME=finally
FINALLY_CONTAINER_NAME=finally-app
FINALLY_VOLUME_NAME=finally-data
PORT=8000
