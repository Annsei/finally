# FinAlly runtime configuration
# Copy to .env, keep .env private, and see planning/OPERATIONS.md for modes.

# ---------------------------------------------------------------------------
# Runtime boundary
# ---------------------------------------------------------------------------

# local-demo: loopback-only, name-only demo login is allowed.
# classroom-server: shared single-replica server; requires the two secrets below
# and FINALLY_SINGLE_REPLICA=true.
FINALLY_RUNTIME_MODE=local-demo

# Backend bind expectation used by RuntimeSettings/backend/run.py. local-demo
# accepts loopback hosts only. Docker still listens on 0.0.0.0 inside the
# container; FINALLY_BIND_HOST below controls the host-published interface.
FINALLY_HOST=127.0.0.1
FINALLY_SINGLE_REPLICA=true

# Required in classroom-server; use independent random values of 32+ bytes.
# Never reuse the OpenRouter key here.
FINALLY_SERVER_AUTH_SECRET=
# Blank in local-demo uses the loopback-only value "local-demo-admin".
FINALLY_ADMIN_TOKEN=

# Bearer request safety and quote freshness gates.
FINALLY_MAX_BEARER_BODY_BYTES=65536
FINALLY_QUOTE_MAX_AGE_SECONDS=45

# ---------------------------------------------------------------------------
# Product integrations and market behavior
# ---------------------------------------------------------------------------

# Required only for live AI calls. Leave empty when LLM_MOCK=true.
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) key for real US market data. Empty uses the
# built-in simulator. The CN profile always uses its configured simulator.
MASSIVE_API_KEY=

# Deterministic LLM behavior for tests/offline demonstrations.
LLM_MOCK=false

# Direct backend launches use this profile. docker-compose.yml pins its US and
# CN services independently, so one database volume never changes market.
FINALLY_MARKET=us

# Live price feed: auto | simulator | massive | akshare | replay. Default auto
# keeps the long-standing selection exactly (MASSIVE_API_KEY set -> Massive,
# otherwise the built-in simulator). The simulator remains the product
# default; real feeds are explicit teaching-grade opt-ins, never
# investment-grade data. massive requires MASSIVE_API_KEY; akshare (real
# A-share spot quotes) requires FINALLY_MARKET=cn; replay turns stored daily
# bars into accelerated live sessions (see FINALLY_REPLAY_* below).
# Misconfigurations fail startup instead of silently falling back. Real quotes
# freeze once the real exchange closes, so the FINALLY_QUOTE_MAX_AGE_SECONDS
# freshness gate blocks trading until the next real session — expected
# behavior, not an outage; use real feeds during real market hours or keep the
# simulator.
FINALLY_LIVE_SOURCE=auto

# AKShare spot poll cadence in seconds. Default 15, clamped to 5..120;
# invalid values log a warning and use the default. Only read when
# FINALLY_LIVE_SOURCE=akshare.
FINALLY_AKSHARE_POLL_SECONDS=15

# Historical market replay (only read when FINALLY_LIVE_SOURCE=replay).
# Replays stored daily bars as platform-wide live data: one historical
# trading day is compressed into FINALLY_REPLAY_SECONDS_PER_DAY seconds and
# the previous close / CN price-limit band roll with the REAL historical
# values. FROM/TO are ISO dates — set both for an explicit window or leave
# both empty for the most recent 20 commonly-covered trading days. Startup
# auto-fills missing coverage from the committed sample series (never the
# network); a window that stored data cannot cover fails startup with
# guidance (sync real history first via POST /api/market/history/sync).
# SECONDS_PER_DAY defaults to 120, clamped 30..600; BREAK_SECONDS defaults to
# 5, clamped 2..60 (also the CN lunch-break length). LOOP=true restarts at
# the first day after the window ends; false freezes prices when it ends.
#
# Example replay competition on the committed US sample data (coverage runs
# 2023-08-08..2026-06-30 — pick dates inside it):
#   FINALLY_LIVE_SOURCE=replay
#   FINALLY_REPLAY_FROM=2026-06-01
#   FINALLY_REPLAY_TO=2026-06-30
# For a REAL historical window (e.g. the March 2020 circuit-breaker week,
# 2020-03-09..2020-03-20), sync real yfinance history for the watchlist
# first, then set the window to those dates.
FINALLY_REPLAY_FROM=
FINALLY_REPLAY_TO=
FINALLY_REPLAY_SECONDS_PER_DAY=120
FINALLY_REPLAY_BREAK_SECONDS=5
FINALLY_REPLAY_LOOP=true

# Empty commission uses the profile default (US 0 bps, CN 2.5 bps).
FINALLY_COMMISSION_BPS=

# Accelerated simulator session clock. Both values must be positive; invalid or
# non-positive values select the documented 24/7 behavior.
FINALLY_SESSION_OPEN_SECONDS=1800
FINALLY_SESSION_BREAK_SECONDS=120

# Direct local backend default is db/finally.db. Docker Compose overrides this
# to the persistent /app/db/finally.db volume path.
DB_PATH=db/finally.db

# ---------------------------------------------------------------------------
# Host orchestration (scripts and Docker Compose; not backend application vars)
# ---------------------------------------------------------------------------

# Host interface published by Docker. Keep loopback unless intentionally
# operating a secured classroom-server behind TLS/reverse proxy controls.
FINALLY_BIND_HOST=127.0.0.1
FINALLY_US_PORT=8000
FINALLY_CN_PORT=8001

# start_mac.sh/start_windows.ps1 overrides. Compose uses project-scoped volumes
# instead, which prevents different checkouts from sharing a database.
FINALLY_IMAGE_NAME=finally
FINALLY_CONTAINER_NAME=finally-app
FINALLY_VOLUME_NAME=finally-data
PORT=8000
